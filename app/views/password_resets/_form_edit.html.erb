<%= form_with model: user, url: password_reset_edit_path(token: params[:token]), id: "password_form_reset_edit" do |form| %>
  <div class="field">
    <%= form.label :password, "Contraseña", class: "label" %>
    <div class="control">
      <%= form.text_field :password, class: "input" %>
    </div>
  </div>

  <div class="field">
    <%= form.label :password_confirmation, "Confirma la contraseña", class: "label" %>
    <div class="control">
      <%= form.text_field :password_confirmation, class: "input" %>
    </div>
  </div>

  <div class="field">
    <div class="control">
      <%= form.submit "Recuperar contraseña", class: "button is-link" %>
    </div>
  </div>
<% end %>
